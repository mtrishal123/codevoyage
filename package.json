{
  "name": "codevoyage",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered tech stack migration planning using multi-agent analysis",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test:agent1": "npm run build && node dist/test-agent1.js",
    "test:agent2": "npm run build && node dist/test-agent2.js",
    "test:agent3": "npm run build && node dist/test-agent3.js",
    "test:agent4": "npm run build && node dist/test-agent4.js",
    "test:orchestrator": "npm run build && node dist/test-orchestrator.js",
    "analyze": "npm run test:orchestrator"
  },
  "keywords": [
    "ai",
    "migration",
    "tech-stack",
    "multi-agent",
    "subconscious",
    "code-analysis",
    "developer-tools"
  ],
  "author": "Trishal Varma Mudunuri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mtrishal123/codevoyage.git"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "subconscious": "^0.1.9"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}